EVALF_PROVIDER=openai
EVALF_MODEL=gpt-4.1-mini
EVALF_BASE_URL=https://api.openai.com/v1
EVALF_API_KEY=your-api-key-here
EVALF_CONCURRENCY=4
EVALF_REQUEST_TIMEOUT_SECONDS=60
EVALF_PER_SAMPLE_TIMEOUT_SECONDS=120
EVALF_MAX_RETRIES=3
EVALF_TEMPERATURE=0
EVALF_MAX_TOKENS=800
EVALF_THRESHOLD=0.7
EVALF_METRIC_MODE=pass@k
EVALF_K=1
EVALF_METRICS=faithfulness,answer_correctness,answer_relevance,context_coverage
EVALF_OUTPUT=
